{
  "name": "mini-momguide",
  "version": "0.1.0",
  "private": true,
  "description": "맘가이드 학습용 미니 클론 — Express + Sequelize + MySQL + Redis + Elasticsearch + BullMQ",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "db:up": "docker compose up -d mysql redis elasticsearch kibana",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f",
    "db:seed": "tsx src/db/seed.ts",
    "es:reindex": "tsx src/scripts/reindex-products.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@elastic/elasticsearch": "^8.15.0",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "mysql2": "^3.11.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "sequelize": "^6.37.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
